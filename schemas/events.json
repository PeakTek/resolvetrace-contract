{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.resolvetrace.com/v1/events.json",
  "title": "Events endpoint schemas",
  "description": "Schemas for the payload of POST /v1/events and the envelope within.",
  "definitions": {
    "Ulid": {
      "type": "string",
      "format": "ulid",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries."
    },
    "IsoDateTime": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended)."
    },
    "ScrubberReport": {
      "type": "object",
      "description": "Client-side scrubber application report.",
      "additionalProperties": false,
      "required": ["version", "rulesDigest", "applied", "budgetExceeded"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "SDK scrubber version string (e.g. \"sdk@1.4.2\")."
        },
        "rulesDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Hex-encoded SHA-256 of the scrubber ruleset applied."
        },
        "applied": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "description": "List of rule identifiers the SDK applied."
        },
        "budgetExceeded": {
          "type": "boolean",
          "description": "True when the SDK hit the per-event scrub budget and fell back to the overflow policy."
        },
        "durationMs": {
          "type": "number",
          "minimum": 0,
          "description": "Observed scrub duration in milliseconds."
        }
      }
    },
    "EventType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_.\\-:/]+$",
      "description": "Dot- or slash-separated event type identifier."
    },
    "EventAttributes": {
      "type": "object",
      "description": "Customer-provided attribute bag. Keys are camelCase strings.",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "additionalProperties": true
    },
    "EventEnvelope": {
      "type": "object",
      "title": "EventEnvelope",
      "description": "A single event envelope. Enclosed in the `events` array of a batch request body.",
      "additionalProperties": false,
      "required": ["eventId", "type", "capturedAt", "scrubber", "sdk"],
      "properties": {
        "eventId": { "$ref": "#/definitions/Ulid" },
        "sessionId": {
          "$ref": "#/definitions/Ulid",
          "description": "Optional session correlation ULID."
        },
        "type": { "$ref": "#/definitions/EventType" },
        "capturedAt": {
          "$ref": "#/definitions/IsoDateTime",
          "description": "Client wall-clock at capture time."
        },
        "attributes": { "$ref": "#/definitions/EventAttributes" },
        "scrubber": { "$ref": "#/definitions/ScrubberReport" },
        "clockSkewDetected": {
          "type": "boolean",
          "description": "Set by the server when the client timestamp is outside the accepted skew window."
        },
        "sdk": {
          "type": "object",
          "description": "SDK identity stamped on every envelope.",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 32
            },
            "runtime": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          }
        }
      }
    },
    "EventBatchRequest": {
      "type": "object",
      "title": "EventBatchRequest",
      "description": "Request body for `POST /v1/events`.",
      "additionalProperties": false,
      "required": ["events"],
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/definitions/EventEnvelope" },
          "description": "Batch of event envelopes. Max 100 envelopes and 512 KiB uncompressed per batch."
        }
      }
    },
    "EventBatchAcceptedResponse": {
      "type": "object",
      "title": "EventBatchAcceptedResponse",
      "description": "Success response body for `POST /v1/events` (HTTP 202).",
      "additionalProperties": false,
      "required": ["accepted", "duplicates", "receivedAt"],
      "properties": {
        "accepted": {
          "type": "integer",
          "minimum": 0
        },
        "duplicates": {
          "type": "integer",
          "minimum": 0
        },
        "receivedAt": { "$ref": "#/definitions/IsoDateTime" }
      }
    }
  }
}
