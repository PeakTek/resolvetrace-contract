{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.resolvetrace.com/v1/events.json",
  "title": "ResolveTrace event envelope and batch",
  "description": "Wire-format schemas for events sent to POST /v1/events, including the per-event envelope and batch request shape.",
  "definitions": {
    "Actor": {
      "additionalProperties": false,
      "description": "Caller-supplied identity decoration.",
      "type": "object",
      "required": [
        "userId"
      ],
      "properties": {
        "userId": {
          "minLength": 1,
          "maxLength": 128,
          "description": "Caller-provided opaque user identifier. Set by client.identify(...). Opaque to the server; MUST NOT be a PII value.",
          "type": "string"
        },
        "traits": {
          "description": "Free-form trait bag attached by client.identify(...).",
          "type": "object",
          "patternProperties": {
            "^(.*)$": {}
          }
        }
      }
    },
    "CustomEventType": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!(?:view|action|error|perf|ux|support)\\.)[a-zA-Z0-9_.\\-:/]+$",
      "description": "Customer-defined event type. Same open form as before, but the canonical namespaces (view. action. error. perf. ux. support.) are reserved and rejected here.",
      "type": "string"
    },
    "DiagnosticsLevel": {
      "description": "Diagnostics collection level: essential | standard | assisted_support.",
      "anyOf": [
        {
          "const": "essential",
          "type": "string"
        },
        {
          "const": "standard",
          "type": "string"
        },
        {
          "const": "assisted_support",
          "type": "string"
        }
      ]
    },
    "EventAttributes": {
      "description": "Customer-provided attribute bag. Keys are camelCase strings.",
      "type": "object",
      "patternProperties": {
        "^(.*)$": {}
      }
    },
    "EventBatchAcceptedResponse": {
      "additionalProperties": false,
      "title": "EventBatchAcceptedResponse",
      "description": "Success response body for `POST /v1/events` (HTTP 202).",
      "type": "object",
      "required": [
        "accepted",
        "duplicates",
        "receivedAt"
      ],
      "properties": {
        "accepted": {
          "minimum": 0,
          "description": "Number of events accepted for processing.",
          "type": "integer"
        },
        "duplicates": {
          "minimum": 0,
          "description": "Number of events matched in the idempotency window and processed as no-ops.",
          "type": "integer"
        },
        "receivedAt": {
          "format": "date-time",
          "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended).",
          "type": "string"
        }
      }
    },
    "EventBatchRequest": {
      "additionalProperties": false,
      "title": "EventBatchRequest",
      "description": "Request body for `POST /v1/events`.",
      "type": "object",
      "required": [
        "events"
      ],
      "properties": {
        "events": {
          "minItems": 1,
          "maxItems": 100,
          "description": "Batch of event envelopes. Max 100 envelopes and 512 KiB uncompressed per batch.",
          "type": "array",
          "items": {
            "additionalProperties": false,
            "title": "EventEnvelope",
            "description": "A single event envelope. Enclosed in the `events` array of a batch request body.",
            "type": "object",
            "required": [
              "schemaVersion",
              "eventId",
              "type",
              "capturedAt",
              "scrubber",
              "sdk"
            ],
            "properties": {
              "schemaVersion": {
                "minimum": 1,
                "description": "Major version of the shared event schema this envelope conforms to. Producers stamp the current major (currently 1); consumers reject unsupported majors.",
                "type": "integer"
              },
              "eventId": {
                "format": "ulid",
                "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
                "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
                "type": "string"
              },
              "sessionId": {
                "format": "ulid",
                "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
                "description": "Optional session correlation ULID. Required on events that belong to a replay session.",
                "type": "string"
              },
              "type": {
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^(?:(?:view\\.start|view\\.end|action\\.click|action\\.submit|action\\.navigation|error\\.js|error\\.api|error\\.resource|perf\\.api_latency|perf\\.long_task|ux\\.dead_click|ux\\.rage_click|ux\\.repeated_submit|support\\.report_submitted)|(?!(?:view|action|error|perf|ux|support)\\.)[a-zA-Z0-9_.\\-:/]+)$",
                "title": "EventType",
                "description": "Dot- or slash-separated event type identifier. Open vocabulary with a reserved canonical core (e.g. \"view.start\", \"action.click\", or a custom \"app.checkout.completed\").",
                "type": "string"
              },
              "capturedAt": {
                "format": "date-time",
                "description": "Client wall-clock at capture time (the canonical `occurred_at`). The server preserves this and also records its own receive time.",
                "type": "string"
              },
              "context": {
                "additionalProperties": false,
                "title": "EventContext",
                "description": "Shared per-event global context. Optional on the envelope; when present, releaseVersion/locale/market/diagnosticsLevel are required.",
                "type": "object",
                "required": [
                  "releaseVersion",
                  "locale",
                  "market",
                  "diagnosticsLevel"
                ],
                "properties": {
                  "releaseVersion": {
                    "minLength": 1,
                    "maxLength": 256,
                    "description": "Producer release / build version (e.g. \"web@2026.06.1\").",
                    "type": "string"
                  },
                  "locale": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "BCP-47 locale of the session (e.g. \"en-CA\").",
                    "type": "string"
                  },
                  "market": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "Business market / region the session belongs to.",
                    "type": "string"
                  },
                  "diagnosticsLevel": {
                    "description": "Diagnostics collection level: essential | standard | assisted_support.",
                    "anyOf": [
                      {
                        "const": "essential",
                        "type": "string"
                      },
                      {
                        "const": "standard",
                        "type": "string"
                      },
                      {
                        "const": "assisted_support",
                        "type": "string"
                      }
                    ]
                  },
                  "routeName": {
                    "maxLength": 256,
                    "description": "Logical route / screen name (not the raw URL).",
                    "type": "string"
                  },
                  "routeType": {
                    "maxLength": 64,
                    "description": "Route classification (e.g. \"page\", \"modal\", \"tab\").",
                    "type": "string"
                  },
                  "componentId": {
                    "maxLength": 256,
                    "description": "Stable component identifier.",
                    "type": "string"
                  },
                  "componentType": {
                    "maxLength": 128,
                    "description": "Component classification.",
                    "type": "string"
                  },
                  "browserFamily": {
                    "maxLength": 64,
                    "description": "Browser family (e.g. \"Chrome\").",
                    "type": "string"
                  },
                  "browserVersion": {
                    "maxLength": 64,
                    "description": "Browser version string.",
                    "type": "string"
                  },
                  "osFamily": {
                    "maxLength": 64,
                    "description": "OS family (e.g. \"macOS\").",
                    "type": "string"
                  },
                  "deviceType": {
                    "maxLength": 64,
                    "description": "Device classification (e.g. \"desktop\", \"mobile\").",
                    "type": "string"
                  },
                  "viewportWidth": {
                    "minimum": 0,
                    "description": "Viewport width in CSS pixels.",
                    "type": "integer"
                  },
                  "viewportHeight": {
                    "minimum": 0,
                    "description": "Viewport height in CSS pixels.",
                    "type": "integer"
                  },
                  "featureFlags": {
                    "description": "Active feature-flag map at capture time.",
                    "type": "object",
                    "patternProperties": {
                      "^(.*)$": {}
                    }
                  },
                  "experimentVariant": {
                    "maxLength": 128,
                    "description": "Active experiment variant identifier.",
                    "type": "string"
                  },
                  "networkState": {
                    "maxLength": 64,
                    "description": "Coarse network state (e.g. \"online\", \"4g\", \"offline\").",
                    "type": "string"
                  },
                  "pageUrl": {
                    "maxLength": 2048,
                    "description": "Current page URL. Not part of the abstract global_context vocabulary (which uses routeName/routeType); carried here as an explicit optional field for browser producers that capture the raw URL.",
                    "type": "string"
                  },
                  "supportCode": {
                    "maxLength": 64,
                    "description": "Support code correlating user-visible reports to a session. Shape only — generation/lookup is handled in a later wave.",
                    "type": "string"
                  }
                }
              },
              "severity": {
                "description": "Event severity: info | warn | error.",
                "anyOf": [
                  {
                    "const": "info",
                    "type": "string"
                  },
                  {
                    "const": "warn",
                    "type": "string"
                  },
                  {
                    "const": "error",
                    "type": "string"
                  }
                ]
              },
              "durationMs": {
                "minimum": 0,
                "description": "Duration in milliseconds for events that measure one (e.g. perf.api_latency, perf.long_task).",
                "type": "integer"
              },
              "httpStatus": {
                "minimum": 100,
                "maximum": 599,
                "description": "HTTP status code for API-oriented events (e.g. error.api).",
                "type": "integer"
              },
              "attributes": {
                "description": "Customer-provided attribute bag. Keys are camelCase strings.",
                "type": "object",
                "patternProperties": {
                  "^(.*)$": {}
                }
              },
              "scrubber": {
                "additionalProperties": false,
                "description": "Client-side scrubber application report.",
                "type": "object",
                "required": [
                  "version",
                  "rulesDigest",
                  "applied",
                  "budgetExceeded"
                ],
                "properties": {
                  "version": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "SDK scrubber version string (e.g. \"sdk@1.4.2\").",
                    "type": "string"
                  },
                  "rulesDigest": {
                    "pattern": "^sha256:[a-f0-9]{64}$",
                    "description": "Hex-encoded SHA-256 of the scrubber ruleset applied.",
                    "type": "string"
                  },
                  "applied": {
                    "description": "List of rule identifiers the SDK applied (e.g. [\"regex:email\", \"attr:data-rt-mask\"]).",
                    "maxItems": 64,
                    "type": "array",
                    "items": {
                      "minLength": 1,
                      "maxLength": 128,
                      "type": "string"
                    }
                  },
                  "budgetExceeded": {
                    "description": "True when the SDK hit the per-event scrub budget and fell back to the overflow policy.",
                    "type": "boolean"
                  },
                  "durationMs": {
                    "minimum": 0,
                    "description": "Observed scrub duration in milliseconds.",
                    "type": "number"
                  }
                }
              },
              "clockSkewDetected": {
                "description": "Set by the server when the client timestamp is outside the accepted skew window. Clients should not set this.",
                "type": "boolean"
              },
              "sdk": {
                "additionalProperties": false,
                "description": "SDK identity stamped on every envelope.",
                "type": "object",
                "required": [
                  "name",
                  "version"
                ],
                "properties": {
                  "name": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "SDK package identifier (e.g. \"@peaktek/resolvetrace-sdk\").",
                    "type": "string"
                  },
                  "version": {
                    "minLength": 1,
                    "maxLength": 32,
                    "description": "SDK semver, e.g. \"0.1.0\".",
                    "type": "string"
                  },
                  "runtime": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "Free-form runtime identifier (e.g. \"browser\", \"node-20\", \"python-3.12\").",
                    "type": "string"
                  }
                }
              },
              "actor": {
                "additionalProperties": false,
                "description": "Caller-supplied identity decoration.",
                "type": "object",
                "required": [
                  "userId"
                ],
                "properties": {
                  "userId": {
                    "minLength": 1,
                    "maxLength": 128,
                    "description": "Caller-provided opaque user identifier. Set by client.identify(...). Opaque to the server; MUST NOT be a PII value.",
                    "type": "string"
                  },
                  "traits": {
                    "description": "Free-form trait bag attached by client.identify(...).",
                    "type": "object",
                    "patternProperties": {
                      "^(.*)$": {}
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
