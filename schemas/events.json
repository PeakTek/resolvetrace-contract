{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.resolvetrace.com/v1/events.json",
  "title": "ResolveTrace event envelope and batch",
  "description": "Wire-format schemas for events sent to POST /v1/events, including the per-event envelope and batch request shape.",
  "definitions": {
    "EventAttributes": {
      "description": "Customer-provided attribute bag. Keys are camelCase strings.",
      "type": "object",
      "patternProperties": {
        "^(.*)$": {}
      }
    },
    "EventBatchAcceptedResponse": {
      "additionalProperties": false,
      "title": "EventBatchAcceptedResponse",
      "description": "Success response body for `POST /v1/events` (HTTP 202).",
      "type": "object",
      "properties": {
        "accepted": {
          "minimum": 0,
          "description": "Number of events accepted for processing.",
          "type": "integer"
        },
        "duplicates": {
          "minimum": 0,
          "description": "Number of events matched in the idempotency window and processed as no-ops.",
          "type": "integer"
        },
        "receivedAt": {
          "format": "date-time",
          "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended).",
          "type": "string"
        }
      },
      "required": [
        "accepted",
        "duplicates",
        "receivedAt"
      ]
    },
    "EventBatchRequest": {
      "additionalProperties": false,
      "title": "EventBatchRequest",
      "description": "Request body for `POST /v1/events`.",
      "type": "object",
      "properties": {
        "events": {
          "minItems": 1,
          "maxItems": 100,
          "description": "Batch of event envelopes. Max 100 envelopes and 512 KiB uncompressed per batch.",
          "type": "array",
          "items": {
            "additionalProperties": false,
            "title": "EventEnvelope",
            "description": "A single event envelope. Enclosed in the `events` array of a batch request body.",
            "type": "object",
            "properties": {
              "eventId": {
                "format": "ulid",
                "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
                "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
                "type": "string"
              },
              "sessionId": {
                "format": "ulid",
                "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
                "description": "Optional session correlation ULID. Required on events that belong to a replay session.",
                "type": "string"
              },
              "type": {
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^[a-zA-Z0-9_.\\-:/]+$",
                "description": "Dot- or slash-separated event type identifier (e.g. \"page_view\", \"dom.click\", \"app.checkout.completed\").",
                "type": "string"
              },
              "capturedAt": {
                "format": "date-time",
                "description": "Client wall-clock at capture time. The server preserves this and also records its own receive time.",
                "type": "string"
              },
              "attributes": {
                "description": "Customer-provided attribute bag. Keys are camelCase strings.",
                "type": "object",
                "patternProperties": {
                  "^(.*)$": {}
                }
              },
              "scrubber": {
                "additionalProperties": false,
                "description": "Client-side scrubber application report.",
                "type": "object",
                "properties": {
                  "version": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "SDK scrubber version string (e.g. \"sdk@1.4.2\").",
                    "type": "string"
                  },
                  "rulesDigest": {
                    "pattern": "^sha256:[a-f0-9]{64}$",
                    "description": "Hex-encoded SHA-256 of the scrubber ruleset applied.",
                    "type": "string"
                  },
                  "applied": {
                    "description": "List of rule identifiers the SDK applied (e.g. [\"regex:email\", \"attr:data-rt-mask\"]).",
                    "maxItems": 64,
                    "type": "array",
                    "items": {
                      "minLength": 1,
                      "maxLength": 128,
                      "type": "string"
                    }
                  },
                  "budgetExceeded": {
                    "description": "True when the SDK hit the per-event scrub budget and fell back to the overflow policy.",
                    "type": "boolean"
                  },
                  "durationMs": {
                    "minimum": 0,
                    "description": "Observed scrub duration in milliseconds.",
                    "type": "number"
                  }
                },
                "required": [
                  "version",
                  "rulesDigest",
                  "applied",
                  "budgetExceeded"
                ]
              },
              "clockSkewDetected": {
                "description": "Set by the server when the client timestamp is outside the accepted skew window. Clients should not set this.",
                "type": "boolean"
              },
              "sdk": {
                "additionalProperties": false,
                "description": "SDK identity stamped on every envelope.",
                "type": "object",
                "properties": {
                  "name": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "SDK package identifier (e.g. \"@peaktek/resolvetrace-sdk\").",
                    "type": "string"
                  },
                  "version": {
                    "minLength": 1,
                    "maxLength": 32,
                    "description": "SDK semver, e.g. \"0.1.0\".",
                    "type": "string"
                  },
                  "runtime": {
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "Free-form runtime identifier (e.g. \"browser\", \"node-20\", \"python-3.12\").",
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "version"
                ]
              }
            },
            "required": [
              "eventId",
              "type",
              "capturedAt",
              "scrubber",
              "sdk"
            ]
          }
        }
      },
      "required": [
        "events"
      ]
    },
    "EventEnvelope": {
      "additionalProperties": false,
      "title": "EventEnvelope",
      "description": "A single event envelope. Enclosed in the `events` array of a batch request body.",
      "type": "object",
      "properties": {
        "eventId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "Optional session correlation ULID. Required on events that belong to a replay session.",
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9_.\\-:/]+$",
          "description": "Dot- or slash-separated event type identifier (e.g. \"page_view\", \"dom.click\", \"app.checkout.completed\").",
          "type": "string"
        },
        "capturedAt": {
          "format": "date-time",
          "description": "Client wall-clock at capture time. The server preserves this and also records its own receive time.",
          "type": "string"
        },
        "attributes": {
          "description": "Customer-provided attribute bag. Keys are camelCase strings.",
          "type": "object",
          "patternProperties": {
            "^(.*)$": {}
          }
        },
        "scrubber": {
          "additionalProperties": false,
          "description": "Client-side scrubber application report.",
          "type": "object",
          "properties": {
            "version": {
              "minLength": 1,
              "maxLength": 64,
              "description": "SDK scrubber version string (e.g. \"sdk@1.4.2\").",
              "type": "string"
            },
            "rulesDigest": {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "description": "Hex-encoded SHA-256 of the scrubber ruleset applied.",
              "type": "string"
            },
            "applied": {
              "description": "List of rule identifiers the SDK applied (e.g. [\"regex:email\", \"attr:data-rt-mask\"]).",
              "maxItems": 64,
              "type": "array",
              "items": {
                "minLength": 1,
                "maxLength": 128,
                "type": "string"
              }
            },
            "budgetExceeded": {
              "description": "True when the SDK hit the per-event scrub budget and fell back to the overflow policy.",
              "type": "boolean"
            },
            "durationMs": {
              "minimum": 0,
              "description": "Observed scrub duration in milliseconds.",
              "type": "number"
            }
          },
          "required": [
            "version",
            "rulesDigest",
            "applied",
            "budgetExceeded"
          ]
        },
        "clockSkewDetected": {
          "description": "Set by the server when the client timestamp is outside the accepted skew window. Clients should not set this.",
          "type": "boolean"
        },
        "sdk": {
          "additionalProperties": false,
          "description": "SDK identity stamped on every envelope.",
          "type": "object",
          "properties": {
            "name": {
              "minLength": 1,
              "maxLength": 64,
              "description": "SDK package identifier (e.g. \"@peaktek/resolvetrace-sdk\").",
              "type": "string"
            },
            "version": {
              "minLength": 1,
              "maxLength": 32,
              "description": "SDK semver, e.g. \"0.1.0\".",
              "type": "string"
            },
            "runtime": {
              "minLength": 1,
              "maxLength": 64,
              "description": "Free-form runtime identifier (e.g. \"browser\", \"node-20\", \"python-3.12\").",
              "type": "string"
            }
          },
          "required": [
            "name",
            "version"
          ]
        }
      },
      "required": [
        "eventId",
        "type",
        "capturedAt",
        "scrubber",
        "sdk"
      ]
    },
    "EventType": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_.\\-:/]+$",
      "description": "Dot- or slash-separated event type identifier (e.g. \"page_view\", \"dom.click\", \"app.checkout.completed\").",
      "type": "string"
    },
    "IsoDateTime": {
      "format": "date-time",
      "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended).",
      "type": "string"
    },
    "ScrubberReport": {
      "additionalProperties": false,
      "description": "Client-side scrubber application report.",
      "type": "object",
      "properties": {
        "version": {
          "minLength": 1,
          "maxLength": 64,
          "description": "SDK scrubber version string (e.g. \"sdk@1.4.2\").",
          "type": "string"
        },
        "rulesDigest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Hex-encoded SHA-256 of the scrubber ruleset applied.",
          "type": "string"
        },
        "applied": {
          "description": "List of rule identifiers the SDK applied (e.g. [\"regex:email\", \"attr:data-rt-mask\"]).",
          "maxItems": 64,
          "type": "array",
          "items": {
            "minLength": 1,
            "maxLength": 128,
            "type": "string"
          }
        },
        "budgetExceeded": {
          "description": "True when the SDK hit the per-event scrub budget and fell back to the overflow policy.",
          "type": "boolean"
        },
        "durationMs": {
          "minimum": 0,
          "description": "Observed scrub duration in milliseconds.",
          "type": "number"
        }
      },
      "required": [
        "version",
        "rulesDigest",
        "applied",
        "budgetExceeded"
      ]
    },
    "SdkIdentity": {
      "additionalProperties": false,
      "description": "SDK identity stamped on every envelope.",
      "type": "object",
      "properties": {
        "name": {
          "minLength": 1,
          "maxLength": 64,
          "description": "SDK package identifier (e.g. \"@peaktek/resolvetrace-sdk\").",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "maxLength": 32,
          "description": "SDK semver, e.g. \"0.1.0\".",
          "type": "string"
        },
        "runtime": {
          "minLength": 1,
          "maxLength": 64,
          "description": "Free-form runtime identifier (e.g. \"browser\", \"node-20\", \"python-3.12\").",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ]
    },
    "Ulid": {
      "format": "ulid",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
      "type": "string"
    }
  }
}
