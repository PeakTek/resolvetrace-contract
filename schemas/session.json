{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.resolvetrace.com/v1/session.json",
  "title": "ResolveTrace session lifecycle",
  "description": "Wire-format schemas for session start and end requests and responses.",
  "definitions": {
    "ReleaseChannel": {
      "description": "Customer-reported release channel. The authoritative environment is derived from the API key, not this field.",
      "anyOf": [
        {
          "const": "production",
          "type": "string"
        },
        {
          "const": "staging",
          "type": "string"
        },
        {
          "const": "development",
          "type": "string"
        },
        {
          "const": "canary",
          "type": "string"
        }
      ]
    },
    "SessionClient": {
      "additionalProperties": false,
      "description": "Non-PII client environment metadata attached to the session for analytics.",
      "type": "object",
      "properties": {
        "userAgent": {
          "minLength": 1,
          "maxLength": 512,
          "description": "Client User-Agent string as reported by the host environment.",
          "type": "string"
        },
        "locale": {
          "minLength": 2,
          "maxLength": 35,
          "description": "BCP 47 locale tag (e.g. \"en-CA\", \"fr-FR\").",
          "type": "string"
        },
        "timezone": {
          "minLength": 1,
          "maxLength": 64,
          "description": "IANA timezone identifier (e.g. \"America/Toronto\"). Optional.",
          "type": "string"
        },
        "viewport": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "width",
            "height"
          ],
          "properties": {
            "width": {
              "minimum": 0,
              "maximum": 20000,
              "type": "integer"
            },
            "height": {
              "minimum": 0,
              "maximum": 20000,
              "type": "integer"
            },
            "devicePixelRatio": {
              "minimum": 0,
              "maximum": 16,
              "type": "number"
            }
          }
        }
      }
    },
    "SessionEndReason": {
      "description": "Why the session ended. Informational; does not change server processing.",
      "anyOf": [
        {
          "const": "closed",
          "type": "string"
        },
        {
          "const": "visibility_hidden",
          "type": "string"
        },
        {
          "const": "beforeunload",
          "type": "string"
        },
        {
          "const": "timeout",
          "type": "string"
        },
        {
          "const": "shutdown",
          "type": "string"
        },
        {
          "const": "error",
          "type": "string"
        },
        {
          "const": "inactivity",
          "type": "string"
        },
        {
          "const": "max_duration",
          "type": "string"
        },
        {
          "const": "explicit",
          "type": "string"
        }
      ]
    },
    "SessionEndRequest": {
      "additionalProperties": false,
      "title": "SessionEndRequest",
      "description": "Request body for `POST /v1/session/end`.",
      "type": "object",
      "required": [
        "sessionId",
        "endedAt",
        "reason"
      ],
      "properties": {
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "endedAt": {
          "format": "date-time",
          "description": "Client wall-clock at session end.",
          "type": "string"
        },
        "reason": {
          "description": "Why the session ended. Informational; does not change server processing.",
          "anyOf": [
            {
              "const": "closed",
              "type": "string"
            },
            {
              "const": "visibility_hidden",
              "type": "string"
            },
            {
              "const": "beforeunload",
              "type": "string"
            },
            {
              "const": "timeout",
              "type": "string"
            },
            {
              "const": "shutdown",
              "type": "string"
            },
            {
              "const": "error",
              "type": "string"
            },
            {
              "const": "inactivity",
              "type": "string"
            },
            {
              "const": "max_duration",
              "type": "string"
            },
            {
              "const": "explicit",
              "type": "string"
            }
          ]
        },
        "eventCount": {
          "minimum": 0,
          "description": "Client-side count of events captured in this session. Used for reconciliation diagnostics.",
          "type": "integer"
        },
        "replayChunkCount": {
          "minimum": 0,
          "description": "Client-side count of replay chunks uploaded in this session.",
          "type": "integer"
        }
      }
    },
    "SessionEndResponse": {
      "additionalProperties": false,
      "title": "SessionEndResponse",
      "description": "Response body for `POST /v1/session/end` (HTTP 200).",
      "type": "object",
      "required": [
        "sessionId",
        "acceptedAt"
      ],
      "properties": {
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "acceptedAt": {
          "format": "date-time",
          "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended).",
          "type": "string"
        }
      }
    },
    "SessionStartIdentify": {
      "additionalProperties": false,
      "description": "Identity decoration folded in from a client.identify(...) call that occurred before session start.",
      "type": "object",
      "required": [
        "userId"
      ],
      "properties": {
        "userId": {
          "minLength": 1,
          "maxLength": 128,
          "description": "Customer-provided identified-user identifier. Opaque to the server; MUST NOT be a PII value.",
          "type": "string"
        },
        "traits": {
          "description": "Free-form trait bag attached at session start via client.identify(...).",
          "type": "object",
          "patternProperties": {
            "^(.*)$": {}
          }
        }
      }
    },
    "SessionStartRequest": {
      "additionalProperties": false,
      "title": "SessionStartRequest",
      "description": "Request body for `POST /v1/session/start`.",
      "type": "object",
      "required": [
        "sessionId",
        "startedAt"
      ],
      "properties": {
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "startedAt": {
          "format": "date-time",
          "description": "Client wall-clock at session start.",
          "type": "string"
        },
        "appVersion": {
          "minLength": 1,
          "maxLength": 64,
          "description": "Customer-reported application version (free-form string).",
          "type": "string"
        },
        "releaseChannel": {
          "description": "Customer-reported release channel. The authoritative environment is derived from the API key, not this field.",
          "anyOf": [
            {
              "const": "production",
              "type": "string"
            },
            {
              "const": "staging",
              "type": "string"
            },
            {
              "const": "development",
              "type": "string"
            },
            {
              "const": "canary",
              "type": "string"
            }
          ]
        },
        "client": {
          "additionalProperties": false,
          "description": "Non-PII client environment metadata attached to the session for analytics.",
          "type": "object",
          "properties": {
            "userAgent": {
              "minLength": 1,
              "maxLength": 512,
              "description": "Client User-Agent string as reported by the host environment.",
              "type": "string"
            },
            "locale": {
              "minLength": 2,
              "maxLength": 35,
              "description": "BCP 47 locale tag (e.g. \"en-CA\", \"fr-FR\").",
              "type": "string"
            },
            "timezone": {
              "minLength": 1,
              "maxLength": 64,
              "description": "IANA timezone identifier (e.g. \"America/Toronto\"). Optional.",
              "type": "string"
            },
            "viewport": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "width",
                "height"
              ],
              "properties": {
                "width": {
                  "minimum": 0,
                  "maximum": 20000,
                  "type": "integer"
                },
                "height": {
                  "minimum": 0,
                  "maximum": 20000,
                  "type": "integer"
                },
                "devicePixelRatio": {
                  "minimum": 0,
                  "maximum": 16,
                  "type": "number"
                }
              }
            }
          }
        },
        "userAnonId": {
          "minLength": 1,
          "maxLength": 128,
          "description": "Customer-provided anonymous user identifier. Opaque to the server; MUST NOT be a PII value.",
          "type": "string"
        },
        "identify": {
          "additionalProperties": false,
          "description": "Identity decoration folded in from a client.identify(...) call that occurred before session start.",
          "type": "object",
          "required": [
            "userId"
          ],
          "properties": {
            "userId": {
              "minLength": 1,
              "maxLength": 128,
              "description": "Customer-provided identified-user identifier. Opaque to the server; MUST NOT be a PII value.",
              "type": "string"
            },
            "traits": {
              "description": "Free-form trait bag attached at session start via client.identify(...).",
              "type": "object",
              "patternProperties": {
                "^(.*)$": {}
              }
            }
          }
        }
      }
    },
    "SessionStartResponse": {
      "additionalProperties": false,
      "title": "SessionStartResponse",
      "description": "Response body for `POST /v1/session/start` (HTTP 201).",
      "type": "object",
      "required": [
        "sessionId",
        "acceptedAt",
        "supportCode"
      ],
      "properties": {
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "acceptedAt": {
          "format": "date-time",
          "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended).",
          "type": "string"
        },
        "supportCode": {
          "pattern": "^[0-9A-HJKMNP-TV-Z]{8}$",
          "description": "Per-session support code (Crockford base32, 8 chars, uppercase canonical). Server-minted on session start; the SDK surfaces it for \"Support code: XXXXXXXX\" display.",
          "type": "string"
        }
      }
    },
    "SessionViewport": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "minimum": 0,
          "maximum": 20000,
          "type": "integer"
        },
        "height": {
          "minimum": 0,
          "maximum": 20000,
          "type": "integer"
        },
        "devicePixelRatio": {
          "minimum": 0,
          "maximum": 16,
          "type": "number"
        }
      }
    }
  }
}
