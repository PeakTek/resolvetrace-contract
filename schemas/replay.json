{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.resolvetrace.com/v1/replay.json",
  "title": "ResolveTrace replay chunk upload flow",
  "description": "Wire-format schemas for the two-step replay upload (POST /v1/replay/signed-url to obtain a pre-signed URL, POST /v1/replay/complete to finalize the chunk manifest).",
  "definitions": {
    "ReplayManifestRequest": {
      "additionalProperties": false,
      "title": "ReplayManifestRequest",
      "description": "Request body for `POST /v1/replay/complete`.",
      "type": "object",
      "properties": {
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "sequence": {
          "minimum": 0,
          "type": "integer"
        },
        "key": {
          "minLength": 1,
          "maxLength": 512,
          "description": "Canonical key previously returned by `POST /v1/replay/signed-url`.",
          "type": "string"
        },
        "bytes": {
          "minimum": 1,
          "maximum": 3145728,
          "description": "Exact byte length of the chunk as uploaded.",
          "type": "integer"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "description": "Lower-case hex SHA-256 of the chunk body.",
          "type": "string"
        },
        "clientUploadedAt": {
          "format": "date-time",
          "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended).",
          "type": "string"
        },
        "scrubber": {
          "additionalProperties": false,
          "description": "Client-side scrubber application report.",
          "type": "object",
          "properties": {
            "version": {
              "minLength": 1,
              "maxLength": 64,
              "description": "SDK scrubber version string (e.g. \"sdk@1.4.2\").",
              "type": "string"
            },
            "rulesDigest": {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "description": "Hex-encoded SHA-256 of the scrubber ruleset applied.",
              "type": "string"
            },
            "applied": {
              "description": "List of rule identifiers the SDK applied (e.g. [\"regex:email\", \"attr:data-rt-mask\"]).",
              "maxItems": 64,
              "type": "array",
              "items": {
                "minLength": 1,
                "maxLength": 128,
                "type": "string"
              }
            },
            "budgetExceeded": {
              "description": "True when the SDK hit the per-event scrub budget and fell back to the overflow policy.",
              "type": "boolean"
            },
            "durationMs": {
              "minimum": 0,
              "description": "Observed scrub duration in milliseconds.",
              "type": "number"
            }
          },
          "required": [
            "version",
            "rulesDigest",
            "applied",
            "budgetExceeded"
          ]
        }
      },
      "required": [
        "sessionId",
        "sequence",
        "key",
        "bytes",
        "sha256",
        "clientUploadedAt",
        "scrubber"
      ]
    },
    "ReplayManifestResponse": {
      "additionalProperties": false,
      "title": "ReplayManifestResponse",
      "description": "Response body for `POST /v1/replay/complete` (HTTP 200).",
      "type": "object",
      "properties": {
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "sequence": {
          "minimum": 0,
          "type": "integer"
        },
        "acceptedAt": {
          "format": "date-time",
          "description": "ISO-8601 / RFC 3339 timestamp (UTC recommended).",
          "type": "string"
        },
        "durable": {
          "description": "True once the manifest row has been durably written. Always true on a 200/201 response.",
          "type": "boolean"
        }
      },
      "required": [
        "sessionId",
        "sequence",
        "acceptedAt",
        "durable"
      ]
    },
    "ReplaySignedUrlRequest": {
      "additionalProperties": false,
      "title": "ReplaySignedUrlRequest",
      "description": "Request body for `POST /v1/replay/signed-url`.",
      "type": "object",
      "properties": {
        "sessionId": {
          "format": "ulid",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
          "description": "ULID (Crockford base32, 26 chars). Generated client-side by the SDK at capture time and preserved across retries.",
          "type": "string"
        },
        "sequence": {
          "minimum": 0,
          "description": "Monotonic chunk sequence number within the session, starting at 0. Uniqueness is per (session, sequence).",
          "type": "integer"
        },
        "approxBytes": {
          "minimum": 1,
          "maximum": 3145728,
          "description": "SDK estimate of chunk size, in bytes. Used to pre-validate against the chunk size ceiling.",
          "type": "integer"
        },
        "contentType": {
          "description": "Content type of the chunk body. Must match the upload exactly.",
          "const": "application/vnd.resolvetrace.replay+rrweb",
          "type": "string"
        }
      },
      "required": [
        "sessionId",
        "sequence",
        "approxBytes",
        "contentType"
      ]
    },
    "ReplaySignedUrlResponse": {
      "additionalProperties": false,
      "title": "ReplaySignedUrlResponse",
      "description": "Response body for `POST /v1/replay/signed-url` (HTTP 201).",
      "type": "object",
      "properties": {
        "uploadUrl": {
          "format": "uri",
          "description": "Short-lived presigned URL the SDK uploads the chunk to (HTTP PUT).",
          "type": "string"
        },
        "key": {
          "minLength": 1,
          "maxLength": 512,
          "description": "Canonical object key assigned to this chunk.",
          "type": "string"
        },
        "expiresAt": {
          "format": "date-time",
          "description": "RFC 3339 timestamp after which the signed URL is rejected.",
          "type": "string"
        },
        "maxBytes": {
          "minimum": 1,
          "maximum": 3145728,
          "description": "Hard byte cap encoded into the signed URL. Uploads larger than this are rejected by the signature.",
          "type": "integer"
        },
        "requiredHeaders": {
          "description": "Headers the SDK must send with the PUT upload exactly as specified. Missing or altered values cause the upload to be rejected.",
          "type": "object",
          "patternProperties": {
            "^(.*)$": {
              "minLength": 1,
              "maxLength": 512,
              "type": "string"
            }
          }
        }
      },
      "required": [
        "uploadUrl",
        "key",
        "expiresAt",
        "maxBytes",
        "requiredHeaders"
      ]
    }
  }
}
